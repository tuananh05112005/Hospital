# Dependency directories
node_modules/
jspm_packages/

# Environment variables (chứa API key, mật khẩu cơ sở dữ liệu - tuyệt đối không đưa lên Git)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env

# Build outputs (thư mục build tự động)
dist/
tmp/
out/
.next/
.nuxt/

# Logs (file nhật ký hệ thống)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDEs and editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Uploads (thư mục lưu tệp bệnh án/kết quả tải lên)
backend/uploads/*
!backend/uploads/.gitkeep
